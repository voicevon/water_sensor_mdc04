 467          -------------------------------------------------------------------------*/
 468          float CoscfgtoCapOffset(unsigned char osCfg)
 469          {
 470   1        unsigned char i; 
 471   1        float Coffset = 0.0; 
 472   1      
 473   1        for(i = 0; i < 8; i++) 
 474   1        {
 475   2          if(osCfg & 0x01) Coffset += COS_Factor[i];
 476   2          osCfg >>= 1;
 477   2        }
 478   1        
 479   1        return Coffset;
 480   1      }
