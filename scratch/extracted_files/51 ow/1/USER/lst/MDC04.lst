 323           int ReadTempCap1(unsigned short *iTemp, unsigned short *iCap1)
 324          { 
 325   1        unsigned char scrb[sizeof(MDC04_SCRATCHPAD_READ)];
 326   1        MDC04_SCRATCHPAD_READ *scr = (MDC04_SCRATCHPAD_READ *) scrb;
 327   1      
