 186          int ReadCosConfig(unsigned char *Coscfg)
 187          { 
 188   1        unsigned char scrb[sizeof(MDC04_SCRPARAMETERS)];
 189   1        MDC04_SCRPARAMETERS *scr = (MDC04_SCRPARAMETERS *) scrb;
