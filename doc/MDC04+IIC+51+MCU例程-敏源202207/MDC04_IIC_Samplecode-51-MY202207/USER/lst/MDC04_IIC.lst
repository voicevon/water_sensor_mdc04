C51 COMPILER V9.54   MDC04_IIC                                                             07/26/2022 19:10:23 PAGE 9   

 487          unsigned char CapRangetocfbCfg(float fsCap)
 488          {
 489   1        int i; unsigned char CfbCfg = 0x00;
 490   1        
 491   1        fsCap = fsCap * (3.6/0.507);
 492   1        
 493   1        fsCap -= CFB.Cfb0;
 494   1        
 495   1        for(i = 5; i >= 0; i--)
 496   1        {
 497   2          if(fsCap >= CFB.Factor[i])
 498   2          {
 499   3            fsCap -= CFB.Factor[i];
 500   3            CfbCfg |= (0x01 << i);
 501   3          }     
 502   2        }
 503   1        
 504   1        return CfbCfg;  
 505   1      }
