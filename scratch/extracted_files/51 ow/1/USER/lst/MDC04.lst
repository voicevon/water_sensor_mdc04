 209          /**
 210            * @brief  将偏置电容配置转换为对应的偏置电容数值（pF）
 211            * @param  osCfg：偏置电容配置
 212            * @retval 对应偏置电容的数值
 213          */
 214          float CoscfgtoCapOffset(unsigned char  osCfg)
 215          {
 216   1        int i; 
 217   1        float Coffset = 0.0; 
 218   1      
 219   1        for(i = 0; i < 8; i++) 
 220   1        {
 221   2          if(osCfg & 0x01) Coffset += COS_Factor[i];
 222   2          osCfg >>= 1;
 223   2        }
 224   1        
 225   1        return Coffset;
 226   1      }
 227          /**
 228            * @brief  将量程电容配置转换为对应的量程电容数值（pF）
 229            * @param  fbCfg：量程电容配置
 230            * @retval 对应量程电容的数值
 231          */
 232          float CfbcfgtoCapRange(unsigned char  fbCfg)
 233          {
 234   1        int i;  
 235   1        float Crange = CFB.Cfb0;
 236   1        
 237   1        for(i = 0; i <= 5; i++)
C51 COMPILER V9.54   MDC04                                                                 04/13/2022 19:58:02 PAGE 5   

 238   1        {
 239   2          if(fbCfg & 0x01) Crange += CFB.Factor[i];
 240   2          fbCfg >>= 1;
 241   2        }
 242   1      
 243   1        return (0.507/3.6) * Crange;  
 244   1      }
