 507          /**-----------------------------------------------------------------------
 508            * @brief  将量程电容配置转换为对应的量程电容数值（pF）
 509            * @param  fbCfg：量程电容配置
 510            * @retval 对应量程电容的数值
 511          -------------------------------------------------------------------------*/
 512          float CfbcfgtoCapRange(unsigned char fbCfg)
 513          {
 514   1        unsigned char i;  
 515   1        float Crange = CFB.Cfb0;
 516   1        
 517   1        for(i = 0; i <= 5; i++)
 518   1        {
 519   2          if(fbCfg & 0x01) Crange += CFB.Factor[i];
 520   2          fbCfg >>= 1;
 521   2        }
 522   1      
 523   1        return (0.507/3.6) * Crange;  
 524   1      }
