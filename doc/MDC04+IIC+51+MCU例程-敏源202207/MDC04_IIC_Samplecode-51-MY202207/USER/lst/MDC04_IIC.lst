 442          /**-----------------------------------------------------------------------
 443            * @brief  将偏置电容数值（pF）转换为对应的偏置电容配置
 444            * @param  osCap：偏置电容的数值
 445            * @retval 对应偏置配置寄存器的数值
 446          -------------------------------------------------------------------------*/
 447          unsigned char CaptoCoscfg(float osCap)
 448          {
 449   1        int i; unsigned char CosCfg = 0x00;
 450   1        
 451   1        for(i = 7; i >= 0; i--)
 452   1        {
 453   2          if(osCap >= COS_Factor[i])
 454   2          {
 455   3            CosCfg |= (0x01 << i);
 456   3            osCap -= COS_Factor[i];
 457   3          }
 458   2        }
 459   1        
 460   1        return CosCfg;  
 461   1      }
 462          
 463          /**-----------------------------------------------------------------------
 464            * @brief  将偏置电容配置转换为对应的偏置电容数值（pF）
 465            * @param  osCfg：偏置电容配置
