 375          void Convert_TC1(void)
 376          {
 377   1        unsigned short iTemp, iCap1;
 378   1        float fTemp, fCap1,sum_cap,sum_temp;
 379   1        int k1,AVERAGE_NUM =20,count = 0;
 380   1        
 381   1        SetCapChannel(0x01);//CAP_CH1_SEL
 382   1        
 383   1      
 384   1        
 385   1        
 386   1        for( k1 =0;k1<AVERAGE_NUM;k1++)
 387   1        {
 388   2          ConvertTC1();
 389   2          Delay_ms(15);
 390   2          
 391   2          ReadTempCap1(&iTemp, &iCap1) ;
 392   2      //    uart_printf("iCap1=%x  ",iCap1);
 393   2          fTemp=MDC04_OutputtoTemp(iTemp);
 394   2          //f = 15.000 ra = 15.492
 395   2      //    uart_printf("of = %.3f ra = %.3f  ",CapCfg_offset,CapCfg_range);
 396   2          fCap1=MDC04_OutputtoCap(iCap1, CapCfg_offset, CapCfg_range);
 397   2      //    uart_printf(" %.3f    ",fCap1);
 398   2          sum_temp += fTemp;
 399   2          sum_cap += fCap1;
 400   2          count++;
 401   2            Delay_ms(200);
 402   2        //            Delay_ms(500);
 403   2      
 404   2        }
 405   1      
 406   1          
 407   1        if(count >= AVERAGE_NUM)
 408   1        {
 409   2          fCap1 = sum_cap/count;
 410   2          fTemp = sum_temp/count;
 411   2      
 412   2          sum_cap = 0;
 413   2          sum_temp = 0;
 414   2          count=0;
 415   2        }
 416   1        
 417   1        
 418   1        uart_printf("Temp: %.2f Cap1: %.3f\r\n",fTemp,fCap1);
 419   1      
 420   1      }
