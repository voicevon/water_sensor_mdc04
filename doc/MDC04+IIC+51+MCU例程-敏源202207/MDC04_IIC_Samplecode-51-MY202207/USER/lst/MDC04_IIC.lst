 131          /**-----------------------------------------------------------------------
 132            * @brief  读指定电容通道测量结果。和 @ConvertCap联合使用
 133            * @param  ch：电容通道
 134            * @param  icap：16位电容转换结果
 135            * @retval 读结果状态
 136          -------------------------------------------------------------------------*/
 137          int ReadCap(unsigned char ch, unsigned short *icap)
 138          {
 139   1         unsigned char Cap_lsb, Cap_msb, scr_cap_lsb, scr_cap_msb;  
 140   1        
 141   1        switch(ch)
 142   1        {
 143   2          case 2:
 144   2            scr_cap_lsb = SCR_cap2_lsb; 
 145   2            scr_cap_msb = SCR_cap2_msb;
 146   2            break;    
 147   2          case 3:
 148   2            scr_cap_lsb = SCR_cap3_lsb; 
 149   2            scr_cap_msb = SCR_cap3_msb; 
 150   2            break;      
 151   2          case 4:
 152   2            scr_cap_lsb = SCR_cap4_lsb; 
 153   2            scr_cap_msb = SCR_cap4_msb; 
 154   2            break;
 155   2          case 1:       
 156   2          default:
 157   2            scr_cap_lsb = SCR_cap1_lsb; 
 158   2            scr_cap_msb = SCR_cap1_msb;         
 159   2            break;
 160   2        }
 161   1      
 162   1        MDC04_SingleByteRead(scr_cap_lsb, &Cap_lsb);  
 163   1        MDC04_SingleByteRead(scr_cap_msb, &Cap_msb);  
 164   1      
 165   1        *icap = (Cap_msb <<8) | Cap_lsb;
 166   1        
 167   1        return TRUE;  
 168   1      }
